## Step 5: Visualise a Sample Annotation

```python
import cv2, os
import numpy as np

def draw_labels(img_path, lbl_path, class_names, colors):
    img = cv2.imread(img_path)
    h, w = img.shape[:2]
    with open(lbl_path) as f:
        for line in f:
            cls, cx, cy, bw, bh = map(float, line.strip().split())
            cls = int(cls)
            x1 = int((cx - bw/2) * w); y1 = int((cy - bh/2) * h)
            x2 = int((cx + bw/2) * w); y2 = int((cy + bh/2) * h)
            color = colors[cls]
            cv2.rectangle(img, (x1,y1), (x2,y2), color, 2)
            cv2.putText(img, class_names[cls], (x1, y1-5),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.5, color, 1)
    return img

colors = {0: (0,80,255), 1: (0,215,255)}   # red-ish, yellow-ish in BGR
names  = {0: 'alpha_helix', 1: 'beta_sheet'}

sample = draw_labels(
    "dataset/train/images/frame_0001.png",
    "dataset/train/labels/frame_0001.txt",
    names, colors
)
cv2.imwrite("annotation_sample.png", sample)
print("Saved annotation_sample.png")
```

