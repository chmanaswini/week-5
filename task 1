ls dataset/train/labels/ | wc -l   # should be 100
ls dataset/val/labels/ | wc -l     # should be 40

# Spot check a label file
cat dataset/train/labels/frame_0001.txt
# Expected: lines with format: <class> <cx> <cy> <w> <h>
```

**Validation script:**
```python
import os, glob

def validate_labels(label_dir, nc=2):
    errors = []
    for f in glob.glob(f"{label_dir}/*.txt"):
        with open(f) as fp:
            for i, line in enumerate(fp):
                parts = line.strip().split()
                if len(parts) != 5:
                    errors.append(f"{f}:{i} — wrong column count")
                    continue
                cls = int(parts[0])
                coords = list(map(float, parts[1:]))
                if cls >= nc:
                    errors.append(f"{f}:{i} — invalid class {cls}")
                if not all(0.0 <= c <= 1.0 for c in coords):
                    errors.append(f"{f}:{i} — coords out of [0,1] range")
    return errors

errs = validate_labels("dataset/train/labels")
print(f"Errors found: {len(errs)}")
for e in errs[:10]:
    print(e)
```

