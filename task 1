## Step 4: Label File Format Verification

```python
import os, glob

def validate_protein_labels(label_dir, nc=2):
    files = sorted(glob.glob(f"{label_dir}/*.txt"))
    errors, stats = [], {i: 0 for i in range(nc)}

    for fpath in files:
        with open(fpath) as f:
            lines = f.readlines()
        if len(lines) == 0:
            errors.append(f"EMPTY FILE: {fpath}")
            continue
        for i, line in enumerate(lines):
            parts = line.strip().split()
            if len(parts) != 5:
                errors.append(f"{fpath}:{i} — wrong column count ({len(parts)})")
                continue
            cls = int(parts[0])
            cx, cy, w, h = map(float, parts[1:])
            if cls not in range(nc):
                errors.append(f"{fpath}:{i} — invalid class {cls}")
            if not all(0.0 <= v <= 1.0 for v in [cx, cy, w, h]):
                errors.append(f"{fpath}:{i} — coord out of [0,1]: {parts[1:]}")
            if w < 0.01 or h < 0.01:
                errors.append(f"{fpath}:{i} — box too small (w={w:.4f}, h={h:.4f})")
            else:
                stats[cls] += 1

    print(f"Files checked: {len(files)}")
    print(f"Errors found:  {len(errors)}")
    for cls, count in stats.items():
        names = {0: 'alpha_helix', 1: 'beta_sheet'}
        print(f"  {names[cls]}: {count} annotations")
    for e in errors[:10]:
        print(f"  ⚠ {e}")
    return len(errors) == 0

print("=== TRAIN LABELS ===")
ok_train = validate_protein_labels("dataset/train/labels")
print("\n=== VAL LABELS ===")
ok_val   = validate_protein_labels("dataset/val/labels")

print(f"\nDataset ready for training: {ok_train and ok_val}")
```

