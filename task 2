## Alternative: Scale Using Python (PIL)

```python
from PIL import Image
import os, glob

INPUT_DIR = "dataset/train/images"
OUTPUT_DIR = "dataset_scaled/train/images"
TARGET_WIDTH = 384

os.makedirs(OUTPUT_DIR, exist_ok=True)

for path in glob.glob(f"{INPUT_DIR}/*.png"):
    img = Image.open(path)
    w, h = img.size
    new_h = int(h * TARGET_WIDTH / w)
    resized = img.resize((TARGET_WIDTH, new_h), Image.LANCZOS)
    resized.save(os.path.join(OUTPUT_DIR, os.path.basename(path)))
    print(f"Resized {os.path.basename(path)}: {w}×{h} → {TARGET_WIDTH}×{new_h}")
```

