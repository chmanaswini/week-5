## Monitoring Loss Curves

```python
import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv("runs/protein/protein_helix_sheet/results.csv")
df.columns = df.columns.str.strip()

fig, axes = plt.subplots(2, 2, figsize=(14, 10))
fig.suptitle("Protein Secondary Structure Detection — Training Curves", fontsize=14)

# Box regression loss
axes[0,0].plot(df["epoch"], df["train/box_loss"], label="Train", color="#2196F3")
axes[0,0].plot(df["epoch"], df["val/box_loss"],   label="Val",   color="#FF5722")
axes[0,0].set_title("Bounding Box Loss"); axes[0,0].legend()

# Classification loss
axes[0,1].plot(df["epoch"], df["train/cls_loss"], label="Train", color="#4CAF50")
axes[0,1].plot(df["epoch"], df["val/cls_loss"],   label="Val",   color="#F44336")
axes[0,1].set_title("Classification Loss"); axes[0,1].legend()

# mAP@50
axes[1,0].plot(df["epoch"], df["metrics/mAP50"],    label="mAP@50",    color="#9C27B0")
axes[1,0].plot(df["epoch"], df["metrics/mAP50-95"], label="mAP@50-95", color="#673AB7")
axes[1,0].set_title("Mean Average Precision"); axes[1,0].legend()

# Precision & Recall
axes[1,1].plot(df["epoch"], df["metrics/precision(B)"], label="Precision", color="#00BCD4")
axes[1,1].plot(df["epoch"], df["metrics/recall(B)"],    label="Recall",    color="#FF9800")
axes[1,1].set_title("Precision & Recall"); axes[1,1].legend()

for ax in axes.flat:
    ax.set_xlabel("Epoch"); ax.grid(alpha=0.3)

plt.tight_layout()
plt.savefig("training_curves_protein.png", dpi=150)
plt.show()
```

